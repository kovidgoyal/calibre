from __future__ import absolute_import, division, print_function, unicode_literals

from calibre.web.feeds.news import BasicNewsRecipe


class GlasgowHerald(BasicNewsRecipe):
    title = 'Glasgow Herald'
    oldest_article = 1
    max_articles_per_feed = 100
    language = 'en_GB'

    __author__ = 'Kovid Goyal'
    use_embedded_content = False

    no_stylesheets = True
    auto_cleanup = True

    feeds = [
        ('News', 'https://www.heraldscotland.com/news/rss/'),
        ('Sport', 'https://www.heraldscotland.com/sport/rss/'),
        ('Business', 'https://www.heraldscotland.com/business_hq/rss/'),
        ('Lifestyle', 'https://www.heraldscotland.com/life_style/rss/'),
        (
            'Arts & Entertainment',
            'https://www.heraldscotland.com/arts_ents/rss/',
        ),
        ('Politics', 'https://www.heraldscotland.com/politics/rss/'),
        ('Columnists', 'https://www.heraldscotland.com/opinion/columnists/rss/'),
    ]

from calibre.web.feeds.news import BasicNewsRecipe


class HLN_be(BasicNewsRecipe):
    title = 'Het Laatste Nieuws'
    __author__ = 'Darko Miletic'
    description = 'News from Belgium in Dutch'
    publisher = 'HLN'
    category = 'news, politics, Belgium'
    oldest_article = 2
    max_articles_per_feed = 100
    use_embedded_content = False
    no_stylesheets = True
    encoding = 'utf-8'
    language = 'nl_BE'

    conversion_options = {'comments': description, 'tags': category, 'language': 'nl-NL', 'publisher': publisher}

    remove_tags = [dict(name=['form', 'object', 'embed'])]

    keep_only_tags = [
        dict(name='article', attrs={'class': 'article art_detail'}),
    ]

    feeds = [
        ('Alle nieuws', 'http://www.hln.be/rss.xml'),

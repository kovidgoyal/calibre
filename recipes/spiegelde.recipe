        # Kultur / culture
        # (u'Kultur alles', u'http://www.spiegel.de/kultur/index.rss'),
        ('Kultur Kino', 'http://www.spiegel.de/kultur/kino/index.rss'),
        ('Kultur Musik', 'http://www.spiegel.de/kultur/musik/index.rss'),
        ('Kultur TV', 'http://www.spiegel.de/kultur/tv/index.rss'),
        ('Kultur Literatur', 'http://www.spiegel.de/kultur/literatur/index.rss'),
        ('Kultur Videos zu Kino', 'http://www.spiegel.de/video/kino/index.rss'),
        ('Kultur Videos zu Kultur', 'http://www.spiegel.de/video/kultur/index.rss'),
        # Netzwelt / TheNet
        # (u'Netzwelt alles', u'http://www.spiegel.de/netzwelt/index.rss'),
        ('Netzwelt Politk', 'http://www.spiegel.de/netzwelt/netzpolitik/index.rss'),

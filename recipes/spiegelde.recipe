        # Karriere / Career
        # (u'Karriere alles', u'http://www.spiegel.de/karriere/index.rss'),
        ('Karriere Berufsstart', 'http://www.spiegel.de/karriere/berufsstart/index.rss'),
        ('Karriere Beruf', 'http://www.spiegel.de/karriere/berufsleben/index.rss'),
        ('Karriere Ausland', 'http://www.spiegel.de/karriere/ausland/index.rss'),
        # Uni und Schule
        ('Uni und Schule', 'http://www.spiegel.de/unispiegel/index.rss'),

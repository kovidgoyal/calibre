from calibre.web.feeds.news import BasicNewsRecipe


class Lomza(BasicNewsRecipe):
    title = '4Łomza'
    __author__ = 'fenuks'
    description = 'Regionalny portal. Najświeższe informacje z regionu, kulturalne, sportowe. Ogłoszenia, baza biznesu, forum.'
    cover_url = 'http://www.4lomza.pl/i/logo4lomza_m.jpg'
    language = 'pl'
    oldest_article = 15
    no_stylesheets = True
    extra_css = '#foto {float: right; max-width: 200px; margin-left: 10px;} #fotogaleria > div {float:left;} .br {clear: both;}'
    max_articles_per_feed = 100
    remove_tags = [dict(name='div', attrs={'class': ['bxbanner', 'drukuj', 'wyslijznajomemu']})]
    keep_only_tags = [dict(name='div', attrs={'id': 'srodek'})]
    feeds = [('Łomża', 'http://feeds.feedburner.com/4lomza.pl')]

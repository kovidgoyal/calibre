from calibre.web.feeds.news import BasicNewsRecipe


class Nu(BasicNewsRecipe):
    title = 'Nu.nl'
    __author__ = 'Rob Hankel'

    publisher = 'nu.nl'
    description = 'Dutch News'
    category = 'news'
    oldest_article = 7
    max_articles_per_feed = 100
    no_stylesheets = True
    use_embedded_content = False
    encoding = 'utf-8'
    remove_javascript = True
    language = 'nl'

    keep_only_tags = [dict(name='div', attrs={'id': ['leadarticle']})]

    feeds = [
        ('binnenland', 'http://www.nu.nl/feeds/rss/binnenland.rss'),
        ('Algemeen nieuws', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Algemeen'),
        ('Economie', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Economie'),
        ('Internet', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Internet'),
        ('Sport', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Sport'),
        ('Achterklap', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Achterklap'),
        ('Opmerkelijk', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Opmerkelijk'),
        ('Muziek', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Muziek'),
        ('DVD', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=DVD'),
        ('Film', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Film'),
        ('Boek', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Boek'),
        ('Games', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Games'),
        ('Columns', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Columns'),
        ('Cartoon', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Cartoon'),
        ('Lifehacking', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Lifehacking'),
        ('Jurryt', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Jurryt'),
        ('Formule 1', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Formule1'),
        ('Plugged', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Plugged'),
        ('Auto', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Auto'),
        ('Wetenschap', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Wetenschap'),
        ('Gezondheid', 'http://www.nu.nl/deeplink_rss2/index.jsp?r=Gezondheid'),
        ('Dagelijkse tv-tips', 'http://www.nu.nl/tvgids/rss/tips'),
        ('Podcast Algemeen nieuws', 'http://www.nu.nl/podcast.php'),
    ]

    def get_article_url(self, article):
        return article.get('guid', None)

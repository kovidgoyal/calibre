        ('Nacional', 'http://www.diariodeibiza.es/elementosInt/rss/4'),
        ('Internacional', 'http://www.diariodeibiza.es/elementosInt/rss/5'),
        ('Econom\xeda', 'http://www.diariodeibiza.es/elementosInt/rss/6'),
        ('Deportes', 'http://www.diariodeibiza.es/elementosInt/rss/7'),
        ('Sociedad', 'http://www.diariodeibiza.es/elementosInt/rss/8'),
        ('Ciencia', 'http://www.diariodeibiza.es/elementosInt/rss/11'),
        ('Tecnolog\xeda', 'http://www.diariodeibiza.es/elementosInt/rss/12'),
        ('Gente', 'http://www.diariodeibiza.es/elementosInt/rss/13'),
        ('Sucesos', 'http://www.diariodeibiza.es/elementosInt/rss/15'),

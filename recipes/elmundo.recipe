import time

from calibre.ptempfile import PersistentTemporaryFile
from calibre.web.feeds.news import BasicNewsRecipe


class ElMundo(BasicNewsRecipe):
    title = 'El Mundo'
    __author__ = 'Darko Miletic'
    description = 'Lider de informacion en español'
    publisher = 'Unidad Editorial Informacion General S.L.U.'
    category = 'news, politics, Spain'
    oldest_article = 2
    max_articles_per_feed = 100
    no_stylesheets = True
    use_embedded_content = False
    encoding = 'iso8859_15'
    remove_javascript = True
    remove_empty_feeds = True
    language = 'es'
    ignore_duplicate_articles = {'url'}
    masthead_url = 'http://e00-elmundo.uecdn.es/assets/v7/img/svg/elmundo.svg'
    publication_type = 'newspaper'
    articles_are_obfuscated = True
    auto_cleanup = True
    temp_files = []
    extra_css = '''
                                    body{font-family: "PT serif",Georgia,serif,times}
                                    .metadata_noticia{font-size: small}
                                    .pestana_GDP{font-size: small; font-weight:bold}
                                    h1 {color: #333333; font-family: "Clear Sans Bold",Arial,sans-serif,helvetica}
                                    .hora{color: red}
                                    .update{color: gray}
                                    '''

    conversion_options = {'comments': description, 'tags': category, 'language': language, 'publisher': publisher}

    remove_tags = [dict(attrs={'class': lambda x: x and ('aside-tools' or 'publicidad') in x.split()})]

    feeds = [
        ('Portada', 'http://estaticos.elmundo.es/elmundo/rss/portada.xml'),
        ('Deportes', 'http://estaticos.elmundo.es/elmundodeporte/rss/portada.xml'),
        ('Economia', 'http://estaticos.elmundo.es/elmundo/rss/economia.xml'),
        ('Espa\xf1a', 'http://estaticos.elmundo.es/elmundo/rss/espana.xml'),
        ('Internacional', 'http://estaticos.elmundo.es/elmundo/rss/internacional.xml'),
        ('Cultura', 'http://estaticos.elmundo.es/elmundo/rss/cultura.xml'),
        ('Ciencia/Ecolog\xeda', 'http://estaticos.elmundo.es/elmundo/rss/ciencia.xml'),
        ('Comunicaci\xf3n', 'http://estaticos.elmundo.es/elmundo/rss/comunicacion.xml'),
        ('Televisi\xf3n', 'http://estaticos.elmundo.es/elmundo/rss/television.xml'),
        ('Salud', 'http://estaticos.elmundo.es/elmundosalud/rss/portada.xml'),
        ('Solidaridad', 'http://estaticos.elmundo.es/elmundo/rss/solidaridad.xml'),
        ('Su vivienda', 'http://estaticos.elmundo.es/elmundo/rss/suvivienda.xml'),
        ('Motor', 'http://estaticos.elmundo.es/elmundodeporte/rss/motor.xml'),
        ('Madrid', 'http://estaticos.elmundo.es/elmundo/rss/madrid.xml'),
        ('Barcelona', 'http://estaticos.elmundo.es/elmundo/rss/barcelona.xml'),
        ('Pa\xeds Vasco', 'http://estaticos.elmundo.es/elmundo/rss/paisvasco.xml'),
        ('Baleares', 'http://estaticos.elmundo.es/elmundo/rss/baleares.xml'),
        ('Castilla y Le\xf3n', 'http://estaticos.elmundo.es/elmundo/rss/castillayleon.xml'),
        ('Valladolid', 'http://estaticos.elmundo.es/elmundo/rss/valladolid.xml'),
        ('Valencia', 'http://estaticos.elmundo.es/elmundo/rss/valencia.xml'),
        ('Alicante', 'http://estaticos.elmundo.es/elmundo/rss/alicante.xml'),
        ('Castell\xf3n', 'http://estaticos.elmundo.es/elmundo/rss/castellon.xml'),
        ('Andaluc\xeda', 'http://estaticos.elmundo.es/elmundo/rss/andalucia.xml'),
        ('Sevilla', 'http://estaticos.elmundo.es/elmundo/rss/andalucia_sevilla.xml'),
        ('M\xe1laga', 'http://estaticos.elmundo.es/elmundo/rss/andalucia_malaga.xml'),
    ]

    def get_cover_url(self):
        cover = self.masthead_url
        st = time.localtime()
        year = str(st.tm_year)
        month = '%.2d' % st.tm_mon
        day = '%.2d' % st.tm_mday
        cover = 'http://img.kiosko.net/' + '/'.join([year, month, day]) + '/es/elmundo.750.jpg'
        try:
            self.browser.open(cover)
        except Exception:
            self.log('\nPortada no disponible')
        return cover

    def get_obfuscated_article(self, url):
        count = 0
        tries = 5
        html = None
        while count < tries:
            try:
                response = self.browser.open(url)
                html = response.read()
                count = tries
            except Exception:
                print('Retrying download...')
            count += 1
        if html is not None:
            tfile = PersistentTemporaryFile('_fa.html')
            tfile.write(html)
            tfile.close()
            self.temp_files.append(tfile)
            return tfile.name
        return None

    def image_url_processor(self, baseurl, url):
        if url.startswith('//'):
            return 'http:' + url
        if url.startswith('file://'):
            return url.replace('file://', 'http://')
        return url

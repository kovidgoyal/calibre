    description = '\u0418\u043d\u0442\u0435\u0440\u043d\u0435\u0442-\u0438\u0437\u0434\u0430\u043d\u0438\u0435, \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u0438\u0437\u0438\u0440\u0443\u044e\u0449\u0435\u0435\u0441\u044f \u043d\u0430 \u0436\u0443\u0440\u043d\u0430\u043b\u0438\u0441\u0442\u0441\u043a\u0438\u0445 \u0440\u0430\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u044f\u0445. \u041e\u0441\u043d\u043e\u0432\u0430\u043d\u043e \u0432 2020 \u0433\u043e\u0434\u0443 \u0440\u043e\u0441\u0441\u0438\u0439\u0441\u043a\u0438\u043c\u0438 \u0436\u0443\u0440\u043d\u0430\u043b\u0438\u0441\u0442\u0430\u043c\u0438 \u0420\u043e\u043c\u0430\u043d\u043e\u043c \u0410\u043d\u0438\u043d\u044b\u043c \u0438 \u041e\u043b\u0435\u0441\u0435\u0439 \u0428\u043c\u0430\u0433\u0443\u043d.'  # noqa: E501
    __author__ = 'bugmen00t'

from calibre.web.feeds.news import BasicNewsRecipe


class JeuxVideoCom(BasicNewsRecipe):
    title = 'JeuxVideo.com'
    __author__ = 'Malah'
    description = 'La Référence des Jeux Vidéo sur PC et Consoles !'
    oldest_article = 1.5
    language = 'fr'
    max_articles_per_feed = 100
    remove_empty_feeds = True
    use_embedded_content = False
    no_stylesheets = True
    ignore_duplicate_articles = {'title', 'url'}
    keep_only_tags = [dict(id=['news_detail', 'test_txt', 'test_avis'])]
    remove_tags = [dict(name='div', attrs={'id': 'player_video_article'}), dict(name='div', attrs={'class': 'liste-fiches'})]
    masthead_url = 'https://upload.wikimedia.org/wikipedia/commons/3/39/Jeuxvideocom.png'
    feeds = [
        ('Section PC', 'http://www.jeuxvideo.com/rss/rss-pc.xml'),
        ('Section Xbox One', 'http://www.jeuxvideo.com/rss/rss-xo.xml'),
        ('Section PlayStation 4', 'http://www.jeuxvideo.com/rss/rss-ps4.xml'),
        ('Section Xbox 360', 'http://www.jeuxvideo.com/rss/rss-360.xml'),
        ('Section PlayStation 3', 'http://www.jeuxvideo.com/rss/rss-ps3.xml'),
        ('Section Wii U', 'http://www.jeuxvideo.com/rss/rss-wiiu.xml'),
        ('Section Wii', 'http://www.jeuxvideo.com/rss/rss-wii.xml'),
        ('Section Nintendo 3DS', 'http://www.jeuxvideo.com/rss/rss-3ds.xml'),
        ('Section Nintendo DS', 'http://www.jeuxvideo.com/rss/rss-ds.xml'),
        ('Section PlayStation Vita', 'http://www.jeuxvideo.com/rss/rss-vita.xml'),
        ('Section PlayStation Protable', 'http://www.jeuxvideo.com/rss/rss-psp.xml'),
        ('Section Android', 'http://www.jeuxvideo.com/rss/rss-android.xml'),
        ('Section Iphone', 'http://www.jeuxvideo.com/rss/rss-iphone.xml'),
        ('Section Web', 'http://www.jeuxvideo.com/rss/rss-wb.xml'),
        ('Autres news', 'http://www.jeuxvideo.com/rss/rss-news.xml'),
        ('Autres vidéos', 'http://www.jeuxvideo.com/rss/rss-videos.xml'),
        ('Autres articles', 'http://www.jeuxvideo.com/rss/rss.xml'),
    ]

'''
politiken.dk
'''

from calibre.web.feeds.news import BasicNewsRecipe


class Politiken_dk(BasicNewsRecipe):
    title = 'Politiken.dk'
    __author__ = 'Darko Miletic'
    description = 'News from Denmark'
    publisher = 'politiken.dk'
    category = 'news, politics, Denmark'
    oldest_article = 2
    max_articles_per_feed = 100
    no_stylesheets = True
    remove_empty_feeds = True
    use_embedded_content = False
    encoding = 'cp1252'
    language = 'da'

    extra_css = ' body{font-family: Arial,Helvetica,sans-serif } h1{font-family: Georgia,"Times New Roman",Times,serif } '

    conversion_options = {'comment': description, 'tags': category, 'publisher': publisher, 'language': language}

    feeds = [
        ('Tophistorier', 'http://politiken.dk/rss/tophistorier.rss'),
        ('Seneste nyt', 'http://politiken.dk/rss/senestenyt.rss'),
        ('Mest laeste', 'http://politiken.dk/rss/mestlaeste.rss'),
        ('Danmark', 'http://politiken.dk/rss/indland.rss'),
        ('Politik', 'http://politiken.dk/rss/politik.rss'),
        ('Klima', 'http://politiken.dk/rss/klima.rss'),
        ('Internationalt', 'http://politiken.dk/rss/udland.rss'),
        ('Erhverv', 'http://politiken.dk/rss/erhverv.rss'),
        ('Kultur', 'http://politiken.dk/rss/kultur.rss'),
        ('Sport', 'http://politiken.dk/rss/sport.rss'),
        ('Uddannelse', 'http://politiken.dk/rss/uddannelse.rss'),
    ]
    remove_tags_before = dict(name='h1')
    remove_tags = [dict(name=['object', 'link']), dict(name='div', attrs={'class': 'footer'})]

    def print_version(self, url):
        return url + '?service=print'

from calibre.web.feeds.news import BasicNewsRecipe


class BigGovernmentRecipe(BasicNewsRecipe):
    __license__ = 'GPL v3'
    __author__ = 'kwetal'
    language = 'en'
    version = 1

    title = 'Big Government'
    publisher = 'Andrew Breitbart'
    category = 'Political blog'
    description = 'Political news from the USA'

    oldest_article = 30
    max_articles_per_feed = 100
    use_embedded_content = True

    feeds = [('Big Government', 'http://feeds.feedburner.com/breitbart')]

    conversion_options = {'comments': description, 'tags': category, 'language': 'en', 'publisher': publisher}

    extra_css = '''
                body{font-family:verdana,arial,helvetica,geneva,sans-serif;}
                img {float: left; margin-right: 0.5em;}
                '''

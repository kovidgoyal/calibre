from calibre.web.feeds.news import BasicNewsRecipe


class ElConfidencial(BasicNewsRecipe):
    title = 'elEconomista.es'
    oldest_article = 7.0
    __author__ = 'hmeza'
    description = 'elEconomista.es'
    timefmt = ' [%d %b, %Y]'
    publication_type = 'newspaper'
    language = 'es'
    encoding = 'utf-8'
    no_stylesheets = True
    remove_javascript = True

    feeds = [
        ('elEconomista economía', 'https://www.eleconomista.es/rss/rss-economia.php'),
        ('elEconomista gestion', 'https://www.eleconomista.es/rss/rss-gestion.php'),
        ('elEconomista tecnología', 'https://www.eleconomista.es/rss/rss-category.php?category=tecnologia'),
        ('Selección elEconomista', 'https://www.eleconomista.es/rss/rss-seleccion-ee.php'),
        ('Mercados', 'https://www.eleconomista.es/rss/rss-mercados.php'),
    ]

        ('Ekonomi', 'http://yenisafak.com.tr/rss/?xml=ekonomi'),
        ('Dünya', 'http://yenisafak.com.tr/rss/?xml=dunya'),
        ('Aktüel', 'http://yenisafak.com.tr/rss/?xml=aktuel'),
        ('Eğitim', 'http://yenisafak.com.tr/rss/?xml=egitim'),
        ('Spor', 'http://yenisafak.com.tr/rss/?xml=spor'),
        ('Yazarlar', 'http://yenisafak.com.tr/rss/?xml=yazarlar'),
        ('Televizyon', 'http://yenisafak.com.tr/rss/?xml=televizyon'),
        ('Sağlık', 'http://yenisafak.com.tr/rss/?xml=saglik'),
        ('Yurt Haberler', 'http://yenisafak.com.tr/rss/?xml=yurthaberler'),

from calibre.web.feeds.news import BasicNewsRecipe


class LegeArtisRecipe(BasicNewsRecipe):
    __author__ = 'Mori, Tomasz D\u0142ugosz'
    language = 'pl'

    title = 'Lege Artis'
    publisher = 'Olgierd Rudak'
    description = 'Prawie wszystko, co chcieliby\u015bcie wiedzie\u0107 o prawie, ale wstydzili\u015bcie si\u0119 zapyta\u0107'

    max_articles_per_feed = 100

    no_stylesheets = True
    remove_javascript = True
    remove_empty_feeds = True
    extra_css = '''
            img{clear: both;}
    '''

    feeds = [('Lege Artis', 'http://czasopismo.legeartis.org/feed')]

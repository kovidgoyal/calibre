# Pager Widget {{{

def create_pager_widget(on_prev, on_next):
    def create_pager_button(is_prev, label, icon, onclick):
        a = E.a(svgicon(icon), E.span(label), href='javascript:void(0)', class_='calibre-push-button')
        if not is_prev:  # next button should have icon on the right
            a.insertBefore(a.firstChild.nextSibling, a.firstChild)
        a.addEventListener('click', def(evt):
            evt.preventDefault()
            onclick()
        )
        return a

    prev_btn = create_pager_button(True, _('Prev'), 'chevron-left', on_prev)
    next_btn = create_pager_button(False, _('Next'), 'chevron-right', on_next)
    buttons_container = E.div(prev_btn, E.div(), next_btn, class_='bottom-row')
    top_row = E.div(class_='top-row hidden')
    middle_row = E.div(class_='middle-row hidden')

    container = E.div(
        top_row,
        E.hr(),
        middle_row,
        E.hr(),
        buttons_container,
        class_='calibre-pager-widget calibre-group-box',
    )

    def update_container_visibility():
        container.style.display = 'none' if buttons_container.classList.contains('hidden') and top_row.classList.contains('hidden') and middle_row.classList.contains('hidden') else ''

    def set_enabled(has_prev, has_next):
        prev_btn.setAttribute('aria-disabled', 'false' if has_prev else 'true')
        next_btn.setAttribute('aria-disabled', 'false' if has_next else 'true')
        if has_prev or has_next:
            buttons_container.classList.remove('hidden')
        else:
            buttons_container.classList.add('hidden')
        update_container_visibility()

    def set_visible(which, visible):
        if visible:
            which.classList.remove('hidden')
        else:
            which.classList.add('hidden')
        update_container_visibility()

    return {
        'container': container, 'count_msg': buttons_container.firstChild.nextSibling,
        'prev_btn': prev_btn, 'next_btn': next_btn, 'set_enabled': set_enabled,
        'top_row': top_row, 'middle_row': middle_row,
        'set_top_row_visibility': def(visible): set_visible(top_row, visible);,
        'set_middle_row_visibility': def(visible): set_visible(middle_row, visible);,
    }


create_pager_widget.style = '''

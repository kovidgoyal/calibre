DEFAULT_SIZES = {
    'title': '1.4rem',
    'item-list-title': '1.1rem',
    'item-list-subtitle': '0.8rem',
}

DEFAULT_FONTS = {
    'main': 'sans-serif'
}


def theme_variables(is_dark_theme, primary_color):
    attr = 'dark' if is_dark_theme else 'light'
    default_colors = all_settings.ui_highlight_colors.default
    if not primary_color:
        primary_color = default_colors.dark if is_dark_theme else default_colors.light
    if not primary_color.startswith('#'):
        primary_color = '#' + primary_color
    rgb = parse_hex_color(primary_color)
    if not rgb:
        primary_color = default_colors.dark if is_dark_theme else default_colors.light
        rgb = parse_hex_color(primary_color)
    r, g, b = rgb
    ans = {
        '--calibre-color-primary': primary_color,
        '--calibre-color-primary-light': f'rgba({r},{g},{b},0.18)',
        '--calibre-color-primary-light-2': f'rgba({r},{g},{b},0.28)',
    }
    for k in DEFAULT_COLORS:
        ans['--calibre-color-' + k] = DEFAULT_COLORS[k][attr]
    if not is_dark_theme:
        tints = light_mode_primary_tints(rgb)
        for k in Object.keys(tints):
            ans[k] = tints[k]
    return ans


def set_ui_colors(is_dark_theme, primary_color):
    apply_theme_variables(theme_variables(is_dark_theme, primary_color))
    document.documentElement.style.colorScheme = 'dark' if is_dark_theme else 'light'


def browser_in_dark_mode():
    return window.matchMedia('(prefers-color-scheme: dark)').matches


def effective_book_list_is_dark():
    try:
        sd = get_session_data()
        if not sd:
            return browser_in_dark_mode()
        pref = (sd.get('book_list_color_scheme', 'auto') or 'auto') + ''
    except Exception:
        return browser_in_dark_mode()
    if pref is 'dark':
        return True
    if pref is 'light':
        return False
    return browser_in_dark_mode()


def get_saved_color_settings():
    is_dark = effective_book_list_is_dark()
    try:
        sd = get_session_data()
    except Exception:
        sd = None
    colors = sd.get('ui_highlight_colors') if sd else all_settings.ui_highlight_colors.default
    primary_color = (colors?.dark) if is_dark else (colors?.light)
    if not primary_color:
        default_colors = all_settings.ui_highlight_colors.default
        primary_color = default_colors.dark if is_dark else default_colors.light
    return {
        'primary_color': primary_color,
        'is_dark': is_dark,
    }

def apply_book_list_theme():
    s = get_saved_color_settings()
    set_ui_colors(s.is_dark, s.primary_color)
    try:
        set_css(document.body, background_color=get_color('window-background'), color=get_color('window-foreground'))
    except Exception:
        pass


def bind_book_list_color_scheme_listener():
    try:
        mq = window.matchMedia('(prefers-color-scheme: dark)')
    except Exception:
        return

    def on_pref_change(ev):
        try:
            sd = get_session_data()
            if not sd:
                return
            if ((sd.get('book_list_color_scheme', 'auto') or 'auto') + '') is not 'auto':
                return
        except Exception:
            return
        apply_book_list_theme()

    if mq.addEventListener:
        mq.addEventListener('change', on_pref_change)
    else:
        mq.addListener(on_pref_change)


def color_scheme():
    return 'dark' if effective_book_list_is_dark() else 'light'


def css_for_variables():
    s = get_saved_color_settings()
    attr = 'dark' if s.is_dark else 'light'
    ans = v'[]'
    variables = theme_variables(s.is_dark, s.primary_color)
    for k in Object.keys(variables):
        ans.push(f'{k}: {variables[k]};')
    return f':root {{ color-scheme: {attr}; ' + ans.join('\n') + '}\n\n'


def get_color(name):
    return f'var(--calibre-color-{name})'


def color_to_rgba(color):
    # take an arbitrary color spec and return it as [r, g, b, a]
    cvs = document.createElement('canvas')
    cvs.height = 1
    cvs.width = 1
    if color.startsWith('var('):
        color = window.getComputedStyle(document.documentElement).getPropertyValue(color[4:-1])
    ctx = cvs.getContext('2d')
    ctx.fillStyle = color
    ctx.fillRect(0, 0, 1, 1)
    return ctx.getImageData(0, 0, 1, 1).data


def cached_color_to_rgba(color):
    cache = cached_color_to_rgba.cache
    if not cache[color]:
        cache[color] = color_to_rgba(color)
    return cache[color]
cached_color_to_rgba.cache = {}


def get_color_as_rgba(name):
    cache = get_color_as_rgba.cache
    if not cache[name]:
        cache[name] = color_to_rgba(get_color(name))
    return cache[name]
get_color_as_rgba.cache = {}


def get_font_size(name):
    return DEFAULT_SIZES[name]

def get_font_family(name):
    name = name or 'main'
    return DEFAULT_FONTS[name]

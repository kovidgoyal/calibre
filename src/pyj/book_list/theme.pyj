    'border': c('rgba(0,0,0,0.12)', 'rgba(255,255,255,0.12)'),
    'border-subtle': c('rgba(0,0,0,0.08)', 'rgba(255,255,255,0.08)'),
    'scrollbar-thumb': c('rgba(0,0,0,0.26)', 'rgba(255,255,255,0.34)'),
    'scrollbar-thumb-hover': c('rgba(0,0,0,0.38)', 'rgba(255,255,255,0.48)'),

def escape_for_search(x):
    # Minimal escaping for calibre search syntax
    return (x or '').replace('\\', '\\\\').replace('"', '\\"')


def sync_cs_list_row_heights(list_root):
    """Make all list rows the same height (max of siblings) so item-subtitle stacks don't vary row height."""
    if not list_root:
        return
    ul = list_root.querySelector('ul')
    if not ul:
        return
    disp = (window.getComputedStyle(ul).display or '') + ''
    if disp.indexOf('flex') == -1:
        return
    ch = ul.children
    lis = v'[]'
    for i in range(ch.length):
        node = ch[i]
        if node.tagName.toLowerCase() is 'li':
            lis.push(node)
    if lis.length is 0:
        return
    for i in range(lis.length):
        lis[i].style.minHeight = ''
    max_h = 0
    for i in range(lis.length):
        h = lis[i].offsetHeight
        if h > max_h:
            max_h = h
    if max_h <= 0:
        return
    mh = str(max_h) + 'px'
    for i in range(lis.length):
        lis[i].style.minHeight = mh


def title_for_field(field):
    info = browse_field_for(field)
    return info?.name or field or ''


def subtitle_for_field(field):
    return browse_field_for(field)?.description or ''


def rating_search_query_from_display_name(label):
    """Map tag-browser rating label (e.g. ★★★) to calibre search rating:N with N in 1..5."""
    s = (label or '') + ''
    n = 0
    for i in range(s.length):
        if s[i] is '★':
            n += 1
    if n >= 1 and n <= 5:
        return n
    try:
        v = int(Math.round(parseFloat(s)))
        if v >= 1 and v <= 5:
            return v
    except Exception:
        pass
    return 1


def make_search(field, label):
    label = label or ''
    field = field or ''
    if not field:
        return {'search': ''}
    if field is 'rating':
        n = rating_search_query_from_display_name(label)
        return {'search': 'rating:' + str(n)}
    return {'search': f'{field}:"={escape_for_search(label)}"'}


def stars_for_rating(label):
    try:
        n = int(label)
    except Exception:
        n = 0
    n = max(1, min(5, n))
    return '★' * n


def parse_rating_from_api(avg_rating):
    if avg_rating is None or str(avg_rating).strip() == '':
        return None
    try:
        r = float(avg_rating)
    except Exception:
        return None
    if not isFinite(r):
        return None
    r = clamp(r, 0, 5)
    # Keep one decimal as requested for display/tooltip.
    text = '{:.1f}'.format(r)
    return {'value': r, 'text': text}


def create_fractional_rating_stars(avg_rating):
    info = parse_rating_from_api(avg_rating)
    if not info:
        return None
    percent = (info.value / 5.0) * 100.0
    root = E.span(class_='cs-rating-stars', title=info.text)
    root.appendChild(E.span('★★★★★', class_='cs-rating-stars-base'))
    fill = E.span('★★★★★', class_='cs-rating-stars-fill')
    fill.style.width = '{:.1f}%'.format(percent)
    root.appendChild(fill)
    return root


def tags_cache_key():
    q = parse_url_params()
    sd = get_session_data()
    return '|'.join([
        current_library_id() or '',
        q.vl or '',
        q.search or '',
        sd.get('sort_tags_by') + '',
        sd.get('partition_method') + '',
        sd.get('collapse_at') + '',
        sd.get('dont_collapse') + '',
        sd.get('hide_empty_categories') + '',
    ])


cached_names = {}
series_cover_cache = {}
series_cover_inflight = {}
SERIES_COVER_CLASSES = v'["covers-0","covers-1","covers-2","covers-3","covers-4","covers-5"]'


def series_cover_key(library_id, series_name):
    return JSON.stringify([(library_id or '') + '', (series_name or '') + ''])


def series_stack_cover_count(total):
    try:
        n = int(total)
    except Exception:
        return 0
    if n < 1:
        return 0
    n = min(5, n)
    if n > 1 and n % 2 == 0:
        n -= 1
    return n


def set_series_stack_cover_count(div, total):
    count = series_stack_cover_count(total)
    for cls in SERIES_COVER_CLASSES:
        div.classList.remove(cls)
    div.classList.add('covers-' + str(count))
    return count


def series_stack_cover_urls(urls):
    actual = []
    for u in urls or v'[]':
        if u:
            actual.push(u)
    return actual.slice(0, series_stack_cover_count(actual.length))


def render_series_stack_covers(div, urls):
    actual = series_stack_cover_urls(urls)
    while div.firstChild:
        div.removeChild(div.firstChild)
    count = set_series_stack_cover_count(div, actual.length)
    for i, u in enumerate(actual):
        img = E.img(src=u, class_='cover-img cover-' + str(i))
        div.appendChild(img)
    return count


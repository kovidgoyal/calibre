def parse_int(x, default_value):
    try:
        x = int(x)
    except Exception:
        x = default_value
    return x


def clamp(n, lo, hi):
    return max(lo, min(hi, n))


def update_nav_list_url(field, offset, num, query_text=None, replace=True, g=None):
    q = {'field': field, 'offset': str(offset), 'num': str(num)}
    if query_text:
        q.q = query_text
    g = g or parse_url_params().g
    if g:
        q.g = g
    show_panel('nav_list', q, replace=replace)


def create_nav_list_panel(container_id):
    interface_data = get_interface_data()
    lid = url_books_query().library_id
    title = interface_data.library_map[lid]
    update_window_title(title)
    container = document.getElementById(container_id)
    clear(container)
    q = parse_url_params()
    field = q.field or ''
    field_info = browse_field_for(field) or {'kind': 'category'}
    num = clamp(parse_int(q.num, 15), 5, 100)
    offset = max(0, parse_int(q.offset, 0))
    query_text = (q.q or '').toString()
    group_mode = (q.g or 'y').toString()
    if field_info.kind is 'date':
        query_text = ''
    # Tags panel: render all tags progressively on one page (no paging)
    visible_tags = 50
    title = title_for_field(field)
    create_top_bar(container, title=title, action=back, icon='back')
    container.appendChild(E.div())
    body = container.lastChild
    body.classList.add('cs-nav-list')
    body.dataset.field = field
    if field is 'series':
        sd = get_session_data()
        series_mode = sd.get('series_nav_display_mode', 'stack') or 'stack'
        body.dataset.seriesDisplay = series_mode

    top_pager_widget = create_pager_widget(
        def(): update_nav_list_url(field, max(0, offset - num), num, query_text, replace=True);,
        def(): update_nav_list_url(field, offset + num, num, query_text, replace=True);,
    )
    body.appendChild(E.div(top_pager_widget.container, style='margin: 0 0.75rem'))
    status = top_pager_widget.count_msg
    if field_info.kind is not 'date':
        search_inp = E.input(
            type='search',
            placeholder=_('Filter…'),
            value=query_text,
            class_='cs-filter'
        )
        search_inp.addEventListener('keydown', def(ev):
            if ev.key is 'Enter':
                ev.preventDefault()
                apply_btn.click()
        )
        apply_btn = create_button(_('Apply'), icons='search', action=def():
            nonlocal query_text
            query_text = search_inp.value or ''
            update_nav_list_url(field, 0, num, query_text, replace=True)
        )
        top_pager_widget.middle_row.appendChild(search_inp)
        top_pager_widget.middle_row.appendChild(apply_btn)

    def toggle_btn(label, mode):
        a = E.a(href='#', class_='cs-toggle-btn')
        a.setAttribute('aria-pressed', 'true' if group_mode is mode else 'false')
        a.appendChild(E.span(label))
        a.addEventListener('click', def(evt):
            evt.preventDefault()
            update_nav_list_url(field, 0, num, None, replace=True, g=mode)
        )
        return a

    if field_info.kind is 'date':
        group_toggle = E.div(style='display:flex; gap:0.5rem; align-items:center; flex-wrap:wrap')
        group_toggle.appendChild(E.span(_('Group:'), style='opacity:0.75'))
        seg = E.div(class_='cs-toggle')

        seg.appendChild(toggle_btn(_('Year'), 'y'))
        seg.appendChild(toggle_btn(_('Year & Month'), 'ym'))
        group_toggle.appendChild(seg)
        top_pager_widget.middle_row.appendChild(group_toggle)

    top_pager_widget.set_middle_row_visibility(True)
    list_wrap = E.div(class_='cs-list-wrap')
    body.appendChild(list_wrap)
    nav_subtitle = E.p('', class_='cs-nav-subtitle')
    nav_subtitle.style.display = 'none'
    list_container = E.div(class_='cs-list-content')
    bottom_pager = E.div(style='display:none; margin: 0 0.75rem')
    overlay = E.div(class_='cs-loading-overlay', svgicon('cog'), E.span('\xa0' + _('Loading…')))
    list_wrap.appendChild(nav_subtitle)
    list_wrap.appendChild(list_container)
    list_wrap.appendChild(bottom_pager)
    list_wrap.appendChild(overlay)
    list_wrap.classList.add('cs-loading')

    def set_loading(is_loading):
        if is_loading:
            list_wrap.classList.add('cs-loading')
        else:
            # Delay removal slightly to avoid a flash on very fast responses
            setTimeout(def():
                list_wrap.classList.remove('cs-loading')
            , 60)

    def norm(x):
        return (x or '').toString().toLowerCase()

    def to_item(x):
        if x and jstype(x) is 'object' and 'name' in x:
            return x
        s = (x or '') + ''
        return {'name': s, 'count': None, 'avg_rating': None, 'search_name': s}

    def filtered(items):
        if not query_text:
            return items
        nq = norm(query_text)
        ans = []
        for x in items:
            n = (x.name if (x and jstype(x) is 'object') else x) + ''
            if n and norm(n).indexOf(nq) != -1:
                ans.push(x)
        return ans

    series_cover_targets = {}

    def nav_list_rating_count_parts(count, avg_rating):
        sd = get_session_data()
        show_count = sd.get('show_nav_list_book_count', True)
        show_rating = sd.get('show_nav_list_avg_rating', True)
        count_s = None
        rating_s = None
        if show_count and count is not None and str(count).strip() != '':
            n = int(count)
            count_s = _('{} books').format(n)
        if show_rating and avg_rating is not None and str(avg_rating).strip() != '':
            info = parse_rating_from_api(avg_rating)
            if info and info.value > 0:
                rating_s = create_fractional_rating_stars(info.value)
        if not count_s and not rating_s:
            return None
        return {'rating': rating_s, 'count': count_s}

    def format_count_rating(count, avg_rating):
        p = nav_list_rating_count_parts(count, avg_rating)
        if not p:
            return ''
        parts = []
        if p.count:
            parts.push(p.count)
        if p.rating:
            info = parse_rating_from_api(avg_rating)
            if info:
                parts.push(info.text )
        return ' · '.join(parts)

    def browse_cache_key():
        return tags_cache_key() + '|' + field + '|' + group_mode

    def fetch_browse_items(proceed):
        q = parse_url_params()
        sd = get_session_data()
        query = {'library_id': current_library_id(), 'vl': q.vl or '', 'date_group': group_mode}
        if q.search:
            query.search = q.search
        for k in 'sort_tags_by partition_method collapse_at dont_collapse hide_empty_categories'.split(' '):
            query[k] = sd.get(k) + ''

        def done(end_type, xhr, ev):
            if end_type is not 'load':
                proceed(False, xhr.error_html)
                return
            try:
                data = JSON.parse(xhr.responseText)
            except Exception:
                proceed(False, 'Invalid JSON from server')
                return
            proceed(True, data.items or v'[]')

        ajax(f'interface-data/browse-field/{encodeURIComponent(field)}', done, query=query, bypass_cache=False).send()

    def ensure_series_covers(series_name, target_div):
        if not series_name:
            return
        lid = current_library_id()
        key = series_cover_key(lid, series_name)
        series_cover_targets[key] = (series_cover_targets[key] or v'[]')
        series_cover_targets[key].push(target_div)
        cached = series_cover_cache[key]
        if cached:
            apply_series_covers(key, cached)
            return
        if series_cover_inflight[key]:
            return
        series_cover_inflight[key] = True
        query = {
            'library_id': lid,
            'num': '5',
            'search': f'series:"={escape_for_search(series_name)}"'
        }

        def done(end_type, xhr, ev):
            series_cover_inflight[key] = False
            if end_type is not 'load':
                return
            try:
                data = JSON.parse(xhr.responseText)
            except Exception:
                return
            ids = data.search_result?.book_ids or v'[]'
            urls = []
            for bid in ids.slice(0, 5):
                urls.push(cover_url(bid))
            series_cover_cache[key] = urls
            apply_series_covers(key, urls)

        ajax('interface-data/get-books', done, query=query).send()

    def apply_series_covers(key, urls):
        targets = series_cover_targets[key] or v'[]'
        for div in targets:
            render_series_stack_covers(div, urls)

    def render_page(data):
        nonlocal series_cover_targets
        set_loading(False)
        series_cover_targets = {}
        raw = data or v'[]'
        items = [to_item(x) for x in raw]
        items = filtered(items)
        total = items.length or 0

        def make_action(search_query):
            return def(ev):
                if ev:
                    ev.preventDefault()
                show_panel('book_list', query=search_query, replace=False)

        if field is 'tags':
            shown = min(total, visible_tags)
            status.textContent = _('{0} of {1}').format(shown, total)
            top_pager_widget.set_enabled(False, False)

            clear(list_container)
            subtitle = subtitle_for_field(field)
            if subtitle:
                list_container.appendChild(E.p(subtitle, class_='cs-nav-subtitle'))

            bubbles = E.div(class_='cs-tag-bubbles')
            list_container.appendChild(bubbles)

            for it in items.slice(0, shown):
                if not it or not it.name:
                    continue
                meta = format_count_rating(it.count, it.avg_rating)
                label = it.name + ''
                inner = E.span(label)
                if meta:
                    inner = E.span(E.span(label), E.span(' ' + meta, class_='cs-tag-meta'))
                search_query = {'search': it.search or make_search(field, it.search_name or label).search}
                bubbles.appendChild(E.a(
                    href='#',
                    class_='cs-tag-bubble',
                    onclick=make_action(search_query),
                    title=label,
                    inner
                ))

            if shown < total:
                wrap = E.div(class_='cs-show-more-wrap')
                list_container.appendChild(wrap)
                a = E.a(href='#', class_='cs-show-more')
                a.appendChild(svgicon('plus'))
                a.appendChild(E.span(_('Show more')))
                a.addEventListener('click', def(ev):
                    nonlocal visible_tags
                    ev.preventDefault()
                    visible_tags = min(total, visible_tags + 50)
                    render_page(data)
                )
                wrap.appendChild(a)
            bottom_pager.style.display = 'none'
            return
        if offset >= total and total > 0:
            # Clamp to last page
            new_offset = max(0, (Math.floor((total - 1) / num) * num))
            if new_offset is not offset:
                update_nav_list_url(field, new_offset, num, query_text, replace=True)
                return
        end = min(total, offset + num)
        status.textContent = _('{0}–{1} of {2}').format((offset + 1) if total else 0, end, total)
        top_pager_widget.set_enabled(offset > 0, end < total)

        list_items = []

        def make_action(search_query):
            return def(ev):
                if ev:
                    ev.preventDefault()
                show_panel('book_list', query=search_query, replace=False)

        for it in items.slice(offset, offset + num):
            if not it or not it.name:
                continue
            label = it.name + ''
            search_val = it.search_name or label
            search_query = {'search': it.search or make_search(field, search_val).search}
            meta = nav_list_rating_count_parts(it.count, it.avg_rating)
            if field is 'series':
                series_mode = body.dataset.seriesDisplay or 'stack'
                if series_mode is 'list':
                    list_items.push(create_item(label, action=make_action(search_query), nav_list_meta=meta))
                else:
                    covers = E.div(class_='cs-series-stack-covers')
                    set_series_stack_cover_count(covers, it.count)
                    stack = E.div(class_='cs-series-stack-row', covers, E.div(label, class_='cs-series-stack-name'))
                    stack.dataset.seriesName = label
                    list_items.push(create_item(
                        stack, action=make_action(search_query), nav_list_meta=meta,
                        li_class='cs-series-stack-item', row_class='cs-series-stack-item-row'
                    ))
            elif field is 'rating':
                # Use server-provided display name (tag-browser item.name); do not parse as int — names are localized.
                list_items.push(create_item(label, action=make_action(search_query), nav_list_meta=meta))
            else:
                list_items.push(create_item(label, action=make_action(search_query), nav_list_meta=meta))
        subtitle = subtitle_for_field(field)
        nav_subtitle.textContent = subtitle or ''
        nav_subtitle.style.display = 'block' if subtitle else 'none'
        create_item_list(list_container, list_items)

        def flush_row_heights():
            sync_cs_list_row_heights(list_container)

        flush_row_heights()
        raf = window.requestAnimationFrame
        if raf:
            raf(flush_row_heights)

        if field is 'series':
            # After rendering, lazily fetch covers for visible series
            for srow in list_container.querySelectorAll('[data-series-name]'):
                sname = srow.dataset.seriesName
                cdiv = srow.querySelector('.cs-series-stack-covers')
                if cdiv:
                    ensure_series_covers(sname, cdiv)

        # Bottom prev/next mirrors top pager state
        clear(bottom_pager)
        bot_widget = create_pager_widget(
            def(): update_nav_list_url(field, max(0, offset - num), num, query_text, replace=True);,
            def(): update_nav_list_url(field, offset + num, num, query_text, replace=True);,
        )
        bot_widget.set_enabled(offset > 0, end < total)
        bottom_pager.appendChild(bot_widget.container)
        bottom_pager.style.display = ''

    def render(ok, payload):
        set_loading(False)
        if not ok:
            clear(list_container)
            list_container.appendChild(E.div(_('Failed to load list'), style='opacity:0.9; padding: 1rem'))
            list_container.appendChild(E.div(payload or '', style='opacity:0.8; padding: 0 1rem 1rem 1rem; font-size: smaller'))
            return
        # Update without flashing: create_item_list will clear content itself
        names = payload or v'[]'
        cached_names[browse_cache_key()] = names
        render_page(names)

    cached = cached_names[browse_cache_key()]
    if cached:
        render_page(cached)
    else:
        set_loading(True)
        fetch_browse_items(render)

set_panel_handler('nav_list', create_nav_list_panel)

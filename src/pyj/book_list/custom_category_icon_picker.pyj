    'insert-link': '🔗',
    'search': '🔍',
    'ai': '🤖',
    'random': '🎲',
    'check': '✅',
    'highlight': '✨',
    'warning': '⚠️',
    'help': '❓',
    'print': '🖨️',
    'play': '▶️',
    'pause': '⏸️',
    'copy': '📋',
    'send': '📤',
    'hourglass': '⌛',
